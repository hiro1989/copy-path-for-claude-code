{
  "name": "claude-code-line-copy",
  "displayName": "claude-code-line-copy",
  "version": "0.0.1",
  "description": "Copies Claude Code path of active file and line to clipboard on VSCode.",
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "node esbuild.js",
    "lint": "run-s --continue-on-error lint:* lint-dry:tsc",
    "lint-dry": "run-s lint-dry:format lint-dry:oxlint lint-dry:eslint lint-dry:tsc",
    "lint-dry:format": "oxfmt --check",
    "lint-dry:oxlint": "oxlint --max-warnings=0 .",
    "lint-dry:tsc": "tsc --noEmit --pretty false",
    "lint:format": "oxfmt",
    "lint:oxlint": "oxlint --format unix . --max-warnings=0 --fix",
    "package": "node esbuild.js --production",
    "test": "run-s compile test:compile test:run",
    "test:compile": "tsc",
    "test:run": "vscode-test",
    "vscode:prepublish": "pnpm run package",
    "watch": "run-p watch:*",
    "watch:esbuild": "node esbuild.js --watch"
  },
  "devDependencies": {
    "@tsconfig/strictest": "2.0.8",
    "@types/mocha": "10.0.10",
    "@types/node": "24.11.0",
    "@types/vscode": "1.109.0",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "esbuild": "0.27.3",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "0.15.0",
    "typescript": "5.9.3"
  },
  "contributes": {
    "commands": [
      {
        "command": "claude-code-line-copy.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "activationEvents": [],
  "engines": {
    "vscode": "^1.109.0"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
}
