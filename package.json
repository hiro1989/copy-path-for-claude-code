{
  "name": "copy-path-for-claude-code",
  "displayName": "Copy Path for Claude Code",
  "version": "1.5.1",
  "description": "Copy the active file path in Claude Code @path format to the clipboard, with optional line numbers.",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hiro1989/copy-path-for-claude-code.git"
  },
  "publisher": "arx8",
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "node esbuild.js",
    "lint": "run-s --continue-on-error lint:* lint-dry:tsc",
    "lint-dry": "run-s lint-dry:format lint-dry:oxlint lint-dry:eslint lint-dry:tsc",
    "lint-dry:format": "oxfmt --check",
    "lint-dry:oxlint": "oxlint .",
    "lint-dry:tsc": "tsc --noEmit --pretty false",
    "lint:format": "oxfmt",
    "lint:oxlint": "oxlint --format unix . --fix",
    "package": "node esbuild.js --production",
    "release": "run-s package vsce:publish",
    "test": "run-s compile test:compile test:run",
    "test:compile": "tsc",
    "test:run": "vscode-test",
    "tool:update-all-deps": "pnpm dlx npm-check-updates@22.1.1 --configFileName .ncurc.jsonc",
    "vsce:login": "vsce login arx8",
    "vsce:publish": "vsce publish",
    "vscode:prepublish": "pnpm run package",
    "watch": "run-p watch:*",
    "watch:esbuild": "node esbuild.js --watch"
  },
  "devDependencies": {
    "@tsconfig/strictest": "2.0.8",
    "@types/mocha": "10.0.10",
    "@types/node": "24.11.0",
    "@types/vscode": "1.109.0",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.7.1",
    "esbuild": "0.27.3",
    "lefthook": "2.1.3",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "typescript": "5.9.3"
  },
  "contributes": {
    "commands": [
      {
        "command": "copy-path-for-claude-code.copyRelativePath",
        "title": "Copy Relative Path for Claude Code"
      },
      {
        "command": "copy-path-for-claude-code.copyAbsolutePath",
        "title": "Copy Absolute Path for Claude Code"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "copy-path-for-claude-code.copyRelativePath",
          "group": "6_copypath"
        },
        {
          "command": "copy-path-for-claude-code.copyAbsolutePath",
          "group": "6_copypath"
        }
      ]
    },
    "configuration": {
      "title": "Copy Path for Claude Code",
      "properties": {
        "copy-path-for-claude-code.sortPaths": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "When enabled, sort multi-item copy output alphabetically by path and numerically by line number."
        },
        "copy-path-for-claude-code.stripPrefix": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "A string prefix to strip from the beginning of copied relative paths. Useful for monorepo setups where the workspace root adds an unwanted prefix (e.g., \"root/\")."
        }
      }
    },
    "keybindings": [
      {
        "command": "copy-path-for-claude-code.copyRelativePath",
        "when": "editorFocus"
      },
      {
        "command": "copy-path-for-claude-code.copyAbsolutePath",
        "when": "editorFocus"
      }
    ]
  },
  "activationEvents": [],
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
